APP_BASE_URL=http://localhost:3000
AKAHU_COOKIE_SECRET=replace-with-at-least-32-random-characters

# Akahu API
AKAHU_BASE_URL=https://api.akahu.io/v1
AKAHU_OAUTH_URL=https://oauth.akahu.nz
AKAHU_APP_TOKEN=replace-with-akahu-app-id-token
AKAHU_APP_SECRET=replace-with-akahu-app-secret-for-oauth
AKAHU_REDIRECT_URI=http://localhost:3000/api/akahu/callback
# Optional: override manual refresh cooldown. Defaults to 60 minutes without AKAHU_APP_SECRET, 15 minutes with it.
# AKAHU_MANUAL_REFRESH_COOLDOWN_MINUTES=60
# Temporary Demo Bank testing default in code is ONEOFF TRANSACTIONS ACCOUNT.
# Set ENDURING_CONSENT when reverting to enduring consent.
AKAHU_OAUTH_SCOPE=ONEOFF TRANSACTIONS ACCOUNT

# Optional for local Personal App development.
# Paste this in Connect instead when testing through the UI.
AKAHU_USER_TOKEN=replace-with-personal-app-user-access-token
