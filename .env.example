PNZ_BASE_URL=https://api-nomatls.apicentre.middleware.co.nz
PNZ_API_VERSION=v2.3
PNZ_CLIENT_ID=replace-with-sandbox-client-id
PNZ_CLIENT_KEY_ID=replace-with-sandbox-key-id
# This must exactly match one callback URI registered for the app in the PNZ sandbox portal.
# The developer portal callback below is registered for the sample sandbox app.
PNZ_REDIRECT_URI=https://developer.apicentre.middleware.co.nz/openbanking/accounts/v3.0

# Keep this as a single-line PEM value in your real .env.local.
# Do not commit real private keys.
PNZ_CLIENT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----replace-me-----END PRIVATE KEY-----"

APP_BASE_URL=http://localhost:3000
