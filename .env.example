APP_BASE_URL=http://localhost:3000

# Akahu API
AKAHU_BASE_URL=https://api.akahu.io/v1
AKAHU_OAUTH_URL=https://oauth.akahu.nz
AKAHU_APP_TOKEN=replace-with-akahu-app-id-token
AKAHU_APP_SECRET=replace-with-akahu-app-secret-for-oauth
AKAHU_REDIRECT_URI=http://localhost:3000/api/akahu/callback

# Optional for local Personal App development.
# Paste this in Connect instead when testing through the UI.
AKAHU_USER_TOKEN=replace-with-personal-app-user-access-token
